# ============================================
# Instagram Automation — Configuração
# ============================================

# --- Obrigatório ---
GEMINI_API_KEY=sua_chave_gemini_aqui
COMPOSIO_API_KEY=sua_chave_composio_aqui

# --- Instagram (Composio) ---
# Após configurar a chave, conecte sua conta Instagram Business:
# python main.py --setup
COMPOSIO_ENTITY_ID=instagram_bot

# --- Opcional (Hugging Face) ---
HF_TOKEN=seu_token_hf_aqui
HF_IMAGE_MODEL=runwayml/stable-diffusion-v1-5

# --- Logging ---
# Níveis: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# --- Agendamento ---
# Intervalo entre postagens em horas
POST_INTERVAL_HOURS=6
# Máximo de posts por dia
MAX_POSTS_PER_DAY=4

# --- Timeouts (segundos) ---
UPLOAD_TIMEOUT=60
HF_TIMEOUT=120
GEMINI_TIMEOUT=30

# --- Retry ---
MAX_RETRIES=5
RETRY_DELAY=10

# --- Cleanup ---
# Dias para manter mídia gerada antes de limpar
MEDIA_RETENTION_DAYS=7
